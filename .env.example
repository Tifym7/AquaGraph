# Copy to `.env` on the VM (next to docker-compose.prod.yml) and fill in real
# values. `.env` is gitignored - never commit it.

# Postgres credentials. DB_USER must NOT be a Postgres reserved name.
DB_USER=aquagraph
DB_PASSWORD=change-me-to-a-long-random-string

# Flask session/JWT signing key. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Which image tag to run. CI pushes :latest and :<git-sha>. Pin to a sha to
# roll back: IMAGE=ghcr.io/tifym7/aquagraph:<sha>
IMAGE=ghcr.io/tifym7/aquagraph:latest

# Cloudflare Tunnel connector token. Created in the Cloudflare Zero Trust
# dashboard (Networks → Tunnels). This is what makes the site reachable -
# there is no public web port on the VM.
CF_TUNNEL_TOKEN=paste-the-tunnel-token-here

# Gunicorn sizing. 1 worker fits a 1 GB B1s VM (each worker loads the river
# JSON into RAM). Bump to 2 only on a 2 GB+ VM.
GUNICORN_WORKERS=1
GUNICORN_THREADS=4

# ----------------------------------------------------------------------------
# Satellite ingestion pipeline (WORKER HOST ONLY - not the app VM).
# See docs/PIPELINE.md and docs/GEE_SERVICE_ACCOUNT_SETUP.md.
# Zero-budget: no GCS/billing vars - export transport is free getDownloadURL.
# ----------------------------------------------------------------------------
# Absolute host path to the SA key, mounted read-only into the `ingest`
# compose service at /secrets/gee-key.json. Required to start that service.
GEE_KEY_FILE=/home/youruser/aquagraph-gee-key.json
# Rebuild data/rivers_romania.json after each scheduled cycle (map base layer
# refreshes on next app restart; DB-backed timeline/charts/PDF are always live).
INGEST_REBUILD_SNAPSHOT=0
# Path INSIDE the container (leave as-is; the compose file mounts the key here).
GEE_SERVICE_ACCOUNT_KEY=/secrets/aquagraph-gee-key.json
# Fallback if SA keys are disabled: run `earthengine authenticate` once, then
# set this to 1 and leave GEE_SERVICE_ACCOUNT_KEY empty.
GEE_USE_PERSISTED_CREDENTIALS=0
GEE_PROJECT=cassini2026
GEE_ASSET_RIVERS=projects/cassini2026/assets/eu-hydro
GEE_COUNTRY=Romania

# Full DB URL the worker uses to reach the app's Postgres (history writes).
DB_URL=postgresql://aquagraph:change-me@DB_HOST:5432/aquagraph

# Fetch tuning (defaults are safe for the EE noncommercial tier).
INGEST_FETCH_CHUNK=3000
INGEST_REDUCE_SCALE=30
INGEST_SENSORS=S2,S1
INGEST_SCHEDULE_CRON=0 3 * * *
